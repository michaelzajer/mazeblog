---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;

const sections = [
  {
    slug: 'delivery',
    title: 'Delivery',
    desc: 'Practical frameworks, data models, and working AI agents for tech consultancies that want to know the truth about their delivery health.',
    count: '1 article · 1 demo',
  },
];
---

<BaseLayout title="Home">
  <div class="index-container">
    <div class="index-hero">
      <h1>Maze</h1>
      <p>
        Navigating the complex problems in tech consulting — with articles, frameworks,
        and working AI agents that prove the ideas actually work.
      </p>
    </div>

    <div class="article-grid">
      {sections.map((s) => (
        <a href={`${base}${s.slug}/`} class="article-card">
          <div class="article-card-series">Topic</div>
          <div class="article-card-title">{s.title}</div>
          <div class="article-card-desc">{s.desc}</div>
          <span class="article-card-tag">{s.count}</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
